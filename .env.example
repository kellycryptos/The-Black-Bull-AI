# Groq API Key for AI Chat (Required)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Birdeye API Key (Optional. If provided, used to fetch balance/price. If empty, falls back to public Solana RPC and DexScreener APIs)
BIRDEYE_API_KEY=

# Solana RPC URL (Optional. Defaults to public mainnet beta RPC)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (Optional. Required for the Airdrop Intel tab live data history tracking. Get key from helius.dev)
HELIUS_API_KEY=
